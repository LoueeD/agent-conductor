{
  "name": "agent-conductor",
  "type": "module",
  "version": "0.3.0",
  "description": "A tiny dependency-free TypeScript runtime for structured agent actions.",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LoueeD/agent-conductor.git"
  },
  "bugs": {
    "url": "https://github.com/LoueeD/agent-conductor/issues"
  },
  "homepage": "https://github.com/LoueeD/agent-conductor#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "npm run typecheck && npm test && npm run coverage && npm run smoke",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "smoke": "npm run build && node test/dist-smoke.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "overrides": {
    "vite": "6.4.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@vitest/coverage-v8": "3.2.4",
    "tsdown": "0.12.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
